{
  "manifest_version": 3,
  "name": "Bookmark Canvas",
  "version": "1.0.0",
  "description": "Replace your new tab with an infinite canvas of spatially-clustered bookmarks",
  "chrome_url_overrides": {
    "newtab": "newtab/index.html"
  },
  "permissions": ["bookmarks", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
